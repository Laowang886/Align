enum WorkspaceChatMessageRole {
  USER
  ASSISTANT
}

enum WorkspaceChatActionType {
  CREATE_TASK
  UPDATE_TASK
  MOVE_TASK
  DELETE_TASK

  CREATE_WIKI
  UPDATE_WIKI
  DELETE_WIKI

  CREATE_SPRINT
  START_SPRINT
  COMPLETE_SPRINT
}

enum WorkspaceChatActionStatus {
  PENDING_CONFIRMATION
  CANCELLED
  EXPIRED
  EXECUTING
  SUCCEEDED
  FAILED
}

model WorkspaceChatConversation {
  id          String    @id @default(uuid())
  workspaceId String
  userId      String
  projectId   String?
  title       String    @default("New Chat")
  deletedAt   DateTime?
  purgeAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  messages WorkspaceChatMessage[]
  plans    WorkspaceChatActionPlan[]

  @@index([userId, workspaceId, deletedAt, updatedAt])
  @@index([workspaceId, projectId])
  @@index([purgeAt])
}

model WorkspaceChatMessage {
  id             String                   @id @default(uuid())
  conversationId String
  role           WorkspaceChatMessageRole
  content        String                   @db.Text
  sources        Json?
  createdAt      DateTime                 @default(now())

  conversation WorkspaceChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actionPlan   WorkspaceChatActionPlan?

  @@index([conversationId, createdAt])
}

model WorkspaceChatActionPlan {
  id                 String   @id @default(uuid())
  conversationId     String
  assistantMessageId String   @unique
  expiresAt          DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  conversation     WorkspaceChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  assistantMessage WorkspaceChatMessage      @relation(fields: [assistantMessageId], references: [id], onDelete: Cascade)

  actions WorkspaceChatAction[]

  @@index([conversationId, createdAt])
  @@index([expiresAt])
}

model WorkspaceChatAction {
  id             String                    @id @default(uuid())
  planId         String
  order          Int
  actionType     WorkspaceChatActionType
  payloadVersion Int                       @default(1)
  payload        Json
  displayData    Json
  status         WorkspaceChatActionStatus @default(PENDING_CONFIRMATION)
  result         Json?
  errorMessage   String?                   @db.Text
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  plan WorkspaceChatActionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, order])
  @@index([planId, status])
}
